<!DOCTYPE html>
<html>
<head>

<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">

<title>Vellalankulam </title>

<style>

*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:Arial;
}

body{
background:#f2f7f1;
}

header{
background:linear-gradient(135deg,#2e7d32,#4caf50);
padding:40px 20px;
text-align:center;
color:white;
}

header h1{
font-size:40px;
margin-bottom:10px;
}

header p{
margin-bottom:20px;
}

.insta{
display:inline-block;
padding:12px 24px;
background:white;
color:#2e7d32;
text-decoration:none;
border-radius:30px;
font-weight:bold;
}

.container{
max-width:800px;
margin:auto;
padding:30px;
}

form{
background:white;
padding:25px;
border-radius:15px;
box-shadow:0 3px 15px rgba(0,0,0,.15);
}

input,button{
width:100%;
padding:15px;
margin-top:15px;
border-radius:8px;
border:1px solid #ccc;
}

button{
background:#2e7d32;
color:white;
border:none;
cursor:pointer;
font-size:18px;
}

.gallery{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(220px,1fr));
gap:20px;
margin-top:40px;
}

.card{
background:white;
padding:10px;
border-radius:10px;
box-shadow:0 2px 10px rgba(0,0,0,.1);
}

.card img{
width:100%;
height:250px;
object-fit:cover;
border-radius:8px;
}

.download{
display:block;
margin-top:10px;
padding:10px;
background:#2e7d32;
text-align:center;
color:white;
text-decoration:none;
border-radius:6px;
}

footer{
margin-top:50px;
padding:20px;
background:#1f1f1f;
color:white;
text-align:center;
}

</style>

</head>

<body>

<header>

<h1>🌾 Vellalankulam 🌾</h1>

<p>Upload And Share Village Memories</p>

<a class="insta"
href="https://www.instagram.com/vellalankulam_official?utm_source=ig_web_button_share_sheet&igsh=ZDNlZDc0MzIxNw=="
target="_blank">

Visit Instagram Page

</a>

</header>

<div class="container">

<form id="uploadForm"
action="https://api.web3forms.com/submit"
method="POST"
enctype="multipart/form-data">

<input type="hidden"
name="access_key"
value="93d15198-93c8-46b9-900d-f69d759acfeb">

<input type="hidden"
name="subject"
value="New Village Photo Upload">

<input
type="text"
name="name"
placeholder="Your Name"
required>

<input
type="file"
name="photo"
id="photo"
accept="image/*"
required>

<button>
Upload Photo
</button>

</form>

<div class="gallery" id="gallery"></div>

</div>

<footer>

© Vellalankulam Village Official

</footer>

<script>

const photo=document.getElementById("photo");
const gallery=document.getElementById("gallery");

photo.addEventListener("change",function(){

gallery.innerHTML="";

const file=this.files[0];

if(!file) return;

const reader=new FileReader();

reader.onload=function(e){

gallery.innerHTML=`

<div class="card">

<img src="${e.target.result}">

<a class="download"
href="${e.target.result}"
download="${file.name}">

Download Photo

</a>

</div>

`;

}

reader.readAsDataURL(file);

});

document.getElementById("uploadForm")
.addEventListener("submit",()=>{

alert("Photo Uploaded Successfully");

});

</script>

</body>

</html>
